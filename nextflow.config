// QuantisedEncoder pipeline config.
// Run:  ./nextflow run main.nf              (uses the matrix below)
//   or:  ./nextflow run main.nf --max_steps 10000 --seeds '[42]'   (override params on the CLI)

params {
    dataset   = 'fungi'                                    // WHICH corpus to train/eval. Override: --dataset eukaryota. New corpus = one registry entry below + a downloads.py fn.
    datasets  = [
        fungi:     [ raw: "$projectDir/data/fungi.fasta",     get: 'fungi',     pgym_eval: '--match YEAST'           ],  // fungal model  -> S. cerevisiae assays
        eukaryota: [ raw: "$projectDir/data/eukaryota.fasta", get: 'eukaryota', pgym_eval: '--taxon Human,Eukaryote' ],  // eukaryotic    -> all eukaryote-related taxa
    ]
    // raw + pgym_eval are resolved from datasets[dataset] IN main.nf, not here -- CLI --dataset overrides
    // are merged AFTER this config evaluates, so deriving them here would freeze to the default.

    outdir    = "$projectDir/results"
    sif       = "$projectDir/quantised_encoder.sif"        // one container for all datasets (symlink your existing .sif to this name)
    max_steps = 10000
    eval_every = 500                                       // fewer full-val evals over the long run
    ckpt_every = 0                                         // >0 = snapshot step<N>_<dataset>_s<seed>.pth every N steps -> NLL-vs-step / quant-tolerance-vs-step curves from ONE run

    cluster_ids = ['0.5']                                  // settled (n=1): tight dedup won ProteinGym; homolog depth did NOT help. 0.9/none only inflate MLM top1 via train/test leakage.
    cluster_cov = 0.8                                      // mmseqs linclust coverage
    gate_top1   = 15.0                                     // only ProteinGym/quantise checkpoints above this MLM test top1

    pgym_dir    = "$projectDir/data/proteingym/zero_shot_substitutions_scores"   // DMS + ESM2_8M columns + DMS_substitutions.csv (taxon labels for --taxon)
    dev_match   = "RHOTO,LIPST"                            // held-out SELECTION panel -- DISJOINT from the report (excluded below); non-cerevisiae eukaryotes, valid for both datasets

    distill_teacher = ""                                  // "" = off; e.g. "facebook/esm2_t12_35M_UR50D" to distill during TRAIN (any HF encoder id)
    distill_weight  = 1.0                                 // weight on the representation-matching loss
    contacts_dir    = ""                                  // "" = off; set to "$projectDir/data/contacts" (after `python bin/downloads.py contacts`) to run the attention-contact probe

    seeds = [42, 7, 123]                                   // error bars: cluster_id settled, so run 3 seeds (Hou et al.: ~10% of proteins swing >0.5 NLL across seeds)
    sizes = [                                              // best config from sweep ni3jx7oo
        [tag: 'best', d: 512, h: 8, l: 6, ff: 512],
    ]
}

singularity {
    enabled    = true
    autoMounts = true
    runOptions = '--nv'                                     // expose the GPU inside the container
}

executor {
    queueSize = 1                                          // submit ONE job to SLURM at a time (raise to run N in parallel)
}

process {
    executor       = 'slurm'
    container      = params.sif

    queue = 'gpu-compute'                                 // GPU comes from landing on this partition (this cluster has no `gpu` gres)

    cpus           = 8
    memory         = '32 GB'
    time           = '20h'
    errorStrategy  = 'retry'
    maxRetries     = 1

    withName: PREP {                                     // MMseqs on the full ~3.66M-seq set is CPU/RAM heavy, no GPU
        queue  = 'compute'                               // <-- set to your CPU partition (PREP needs no GPU)
        cpus   = 16
        memory = '64 GB'
        time   = '8h'
    }
    withName: REPORT { queue = 'compute' }               // trivial CPU aggregation
}

env {
    WANDB_MODE       = 'offline'                            // container jobs can't auth (no key/netrc inside) -> log locally, sync from login node
    WANDB_PROJECT    = 'quantised-encoder'
    WANDB_ENTITY     = 'mszczesny101-the-university-of-edinburgh'
    PYTHONUNBUFFERED = '1'                                  // flush train.py output live into .command.out
    HF_HOME              = "$projectDir/.hf"                // distillation teacher cache: compute-node $HOME is read-only -> keep it in the (writable) project dir
    HF_HUB_OFFLINE       = '1'                              // compute nodes have no network -> use the login-node prefetch, never download here
    TRANSFORMERS_OFFLINE = '1'
}

// QuantisedEncoder pipeline config.
// Run:  nextflow run main.nf              (uses the matrix below)
//   or:  nextflow run main.nf --max_steps 10000 --seeds '[42]'   (override params on the CLI)

params {
    data      = "$projectDir/data/fungi_clustered.fasta"   // built once by: python bin/import_fasta.py
    outdir    = "$projectDir/results"
    sif       = "$projectDir/quantised_encoder.sif"
    max_steps = 10000
    eval_every = 500                                       // fewer full-val evals over the long run

    seeds = [42, 7, 123]                                    // fanned out as separate jobs -> PTQ error bars across seeds
    sizes = [                                               // best config from sweep ni3jx7oo (add rows to sweep sizes again)
        [tag: 'best', d: 512, h: 8, l: 6, ff: 512],
    ]
}

singularity {
    enabled    = true
    autoMounts = true
    runOptions = '--nv'                                     // expose the GPU inside the container
}

executor {
    queueSize = 1                                          // submit ONE job to SLURM at a time (raise to run N in parallel)
}

process {
    executor       = 'slurm'
    container      = params.sif
    
    queue = 'gpu-compute'                                 // GPU comes from landing on this partition (this cluster has no `gpu` gres)

    cpus           = 8
    memory         = '32 GB'
    time           = '4h'
    errorStrategy  = 'retry'
    maxRetries     = 1
}

env {
    WANDB_MODE       = 'offline'                            // air-gapped nodes: log locally, sync from the login node
    WANDB_PROJECT    = 'quantised-encoder'
    WANDB_ENTITY     = 'mszczesny101-the-university-of-edinburgh'   // else synced-run URLs print with an empty entity (wandb.ai//...)
    PYTHONUNBUFFERED = '1'                                  // flush train.py output live into .command.out
}
